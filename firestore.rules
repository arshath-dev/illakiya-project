rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection:
    // - Any authenticated user can READ all user documents (doctors need to list patients)
    // - Each user can only WRITE their own document
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Reports: any authenticated user can read and write
    match /reports/{reportId} {
      allow read, write: if request.auth != null;
    }

    // Catch-all: any other collection requires authentication
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
